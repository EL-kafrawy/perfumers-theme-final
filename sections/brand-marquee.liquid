<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .brand-slider-section {
    background-color: #F5F1EB; /* bg-soft-ivory */
    padding-top: 4.5rem; /* py-18 */
    padding-bottom: 4.5rem;
    overflow: hidden;
  }
  .brand-slider__heading {
    text-align: center;
    margin-bottom: 2.25rem; /* mb-9 */
    padding: 0 1.5rem; /* px-6 */
  }
  .brand-slider__heading h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.25rem; /* text-4xl */
    font-weight: 400;
    font-style: italic;
    color: #2E2A33; /* text-[#2E2A33] */
    letter-spacing: -0.025em; /* tracking-tight */
    margin: 0;
  }
  .brand-slider-wrapper {
    position: relative;
    display: flex;
    overflow: hidden;
  }
  .brand-slider-track {
    display: flex;
    gap: 2rem; /* gap-8 */
    width: max-content;
    animation: marquee 30s linear infinite; /* animate-marquee */
    will-change: transform;
    white-space: nowrap;
  }
  .brand-slider-section:hover .brand-slider-track {
    animation-play-state: paused;
  }
  .brand-slider-col {
    display: flex;
    align-items: center;
    gap: 2rem; /* gap-8 */
    padding: 0 1rem; /* px-4 */
  }
  .brand-logo-card {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    flex-shrink: 0;
    width: 6rem; /* w-24 */
    height: 6rem; /* h-24 */
    background-color: #ffffff; /* bg-white */
    border: 1px solid rgba(200, 164, 106, 0.05); /* border-primary/5 */
    border-radius: 9999px; /* rounded-full */
    padding: 1rem; /* p-4 */
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); /* shadow-sm */
    transition: transform 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }
  .brand-logo-card:hover {
    transform: scale(1.05); /* hover:scale-105 */
  }
  .brand-logo-card img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
  }
  
  /* Accessibility: prefers-reduced-motion fallback */
  @media (prefers-reduced-motion: reduce) {
    .brand-slider-track {
      animation: none;
      overflow-x: auto;
      width: 100%;
    }
  }
</style>

<section class="brand-slider-section" id="brandSliderSection">
  <div class="brand-slider__heading">
    <h3>{{ section.settings.heading }}</h3>
  </div>
  <div class="brand-slider-wrapper">
    <div class="brand-slider-track" id="brandSliderTrack">
      {%- for i in (1..2) -%}
        {%- assign is_clone = false -%}
        {%- if i == 2 -%}{%- assign is_clone = true -%}{%- endif -%}
        <div class="brand-slider-col">
          {%- for block in section.blocks -%}
            <a href="{{ block.settings.link | default: '/collections/all' }}" 
               class="brand-logo-card" 
               {% if is_clone %}aria-hidden="true" tabindex="-1"{% endif %}
               {{ block.shopify_attributes }}>
              {%- if block.settings.logo != blank -%}
                <img src="{{ block.settings.logo | image_url: width: 240 }}" alt="{{ block.settings.brand_name | escape }}" width="96" height="96" loading="lazy" draggable="false">
              {%- elsif block.settings.logo_url != blank -%}
                <img src="{{ block.settings.logo_url }}" alt="{{ block.settings.brand_name | escape }}" width="96" height="96" loading="lazy" draggable="false">
              {%- elsif block.settings.logo_file != blank -%}
                <img src="{{ block.settings.logo_file | asset_url }}" alt="{{ block.settings.brand_name | escape }}" width="96" height="96" loading="lazy" draggable="false">
              {%- else -%}
                <span style="font-size: 10px; text-transform: uppercase; font-weight: bold; color: #2D2926;">{{ block.settings.brand_name }}</span>
              {%- endif -%}
            </a>
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- comment -%} JS Duplication removed in favor of Liquid duplication for confirmation {%- endcomment -%}

{% schema %}
{
  "name": "Brand Logo Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by Brand"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand name"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image (uploaded to Shopify Files)"
        },
        {
          "type": "text",
          "id": "logo_url",
          "label": "Logo image URL (Stitch mockups)"
        },
        {
          "type": "text",
          "id": "logo_file",
          "label": "Logo filename (in theme assets)",
          "info": "e.g. brand-logo-dkhoon.jpg"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Marquee",
      "blocks": [
        { "type": "logo", "settings": { "brand_name": "Dkhoon", "logo_file": "brand-logo-dkhoon.jpg" } },
        { "type": "logo", "settings": { "brand_name": "Afnan", "logo_file": "brand-logo-afnan.jpg" } },
        { "type": "logo", "settings": { "brand_name": "Assaf", "logo_file": "brand-logo-assaf.png" } },
        { "type": "logo", "settings": { "brand_name": "Lattafa", "logo_file": "brand-logo-lattafa.png" } },
        { "type": "logo", "settings": { "brand_name": "French Avenue", "logo_file": "brand-logo-french-avenue.jpg" } },
        { "type": "logo", "settings": { "brand_name": "IBRAQ", "logo_file": "brand-logo-ibraq.jpg" } },
        { "type": "logo", "settings": { "brand_name": "Rasasi", "logo_file": "brand-logo-rasasi.webp" } }
      ]
    }
  ]
}
{% endschema %}
