<section class="contact-section" data-section-id="{{ section.id }}">
  <div class="container container--narrow">
    <div class="contact-header text-center">
      <h1 class="contact-title serif-font">{{ page.title | default: 'Contact Us' }}</h1>
      {% if section.settings.subtitle != blank %}
        <p class="contact-subtitle tagline">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="contact-form-wrapper">
      {%- form 'contact', id: 'ContactForm' -%}
        {%- if form.posted_successfully? -%}
          <div class="contact-success text-center">
            <span class="material-symbols-outlined success-icon">check_circle</span>
            <p>{{ 'contact.form.post_success' | t | default: 'Thank you for contacting us. We will get back to you shortly.' }}</p>
          </div>
        {%- elsif form.errors -%}
          <div class="contact-errors">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="contact-fields">
          <div class="field-row">
            <div class="field">
              <label for="ContactForm-name">{{ 'contact.form.name' | t | default: 'Name' }}</label>
              <input type="text" id="ContactForm-name" name="contact[name]" placeholder="Your Name" required>
            </div>
            <div class="field">
              <label for="ContactForm-email">{{ 'contact.form.email' | t | default: 'Email' }}</label>
              <input type="email" id="ContactForm-email" name="contact[email]" placeholder="your@email.com" required>
            </div>
          </div>

          <div class="field">
            <label for="ContactForm-phone">{{ 'contact.form.phone' | t | default: 'Phone' }}</label>
            <input type="tel" id="ContactForm-phone" name="contact[phone]" placeholder="+20 ...">
          </div>

          <div class="field">
            <label for="ContactForm-body">{{ 'contact.form.message' | t | default: 'Message' }}</label>
            <textarea id="ContactForm-body" name="contact[body]" rows="6" placeholder="How can we help you?" required></textarea>
          </div>

          <div class="contact-submit-wrapper">
            <button type="submit" class="btn btn-primary">Send Message</button>
          </div>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: var(--space-4xl) 0;
    background-color: var(--color-background);
  }
  .contact-header {
    margin-bottom: var(--space-2xl);
  }
  .contact-title {
    margin-bottom: var(--space-sm);
  }
  .contact-form-wrapper {
    background-color: var(--color-surface);
    padding: var(--space-xl);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
  }
  .contact-fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .field-row {
    display: flex;
    gap: var(--space-lg);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }
  .field label {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-taupe);
  }
  .field input, 
  .field textarea {
    padding: 12px;
    border: 1px solid var(--color-border-light);
    border-radius: 0;
    font-family: var(--font-sans);
    background-color: var(--color-ivory);
    transition: var(--transition-base);
  }
  .field input:focus, 
  .field textarea:focus {
    outline: none;
    border-color: var(--color-gold);
    box-shadow: 0 0 0 1px var(--color-gold);
  }
  .contact-submit-wrapper {
    margin-top: var(--space-md);
  }
  .contact-success {
    padding: var(--space-lg);
    background-color: rgba(147, 115, 59, 0.1);
    color: var(--color-gold);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-lg);
  }
  .success-icon {
    font-size: 32px;
    margin-bottom: var(--space-sm);
  }
  @media (max-width: 767px) {
    .field-row {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "We would love to hear from you."
    }
  ]
}
{% endschema %}
