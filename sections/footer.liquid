<footer class="site-footer" data-section-id="{{ section.id }}">
  <div class="site-footer__container">
    <div class="site-footer__grid">
      <!-- Brand Block -->
      <div class="site-footer__brand">
        <h5 class="site-footer__logo">PERFUMERS</h5>
        <p class="site-footer__description">
          {{ section.settings.about_text | default: "Redefining luxury through circularity. We believe every scent is a memory waiting to be shared. Authenticated, sustainable, and soulful." }}
        </p>
      </div>

      <!-- Links Grid -->
      {%- comment -%}
        Resolve each link to an explicit setting, then a real always-valid route.
        If still blank, render a non-clickable span (never a dead "#" / empty href).
      {%- endcomment -%}
      {%- assign url_archive = section.settings.link_archive | default: routes.all_products_collection_url -%}
      {%- assign url_shipping = section.settings.link_shipping | default: shop.shipping_policy.url -%}
      {%- assign url_returns = section.settings.link_returns | default: shop.refund_policy.url -%}
      <div class="site-footer__links-grid">
        <!-- Explore -->
        <div>
          <h6 class="site-footer__heading">{{ 'footer.explore' | t }}</h6>
          <ul class="site-footer__list">
            <li><a href="{{ url_archive }}">{{ 'footer.the_archive' | t }}</a></li>
            <li><a href="/pages/sell-your-scent">{{ 'footer.sell_your_scent' | t }}</a></li>
            {%- if section.settings.link_story != blank -%}
              <li><a href="{{ section.settings.link_story }}">{{ 'footer.our_story' | t }}</a></li>
            {%- else -%}
              <li><span class="site-footer__static">{{ 'footer.our_story' | t }}</span></li>
            {%- endif -%}
          </ul>
        </div>
        <!-- Support -->
        <div>
          <h6 class="site-footer__heading">{{ 'footer.support' | t }}</h6>
          <ul class="site-footer__list">
            {%- if url_shipping != blank -%}
              <li><a href="{{ url_shipping }}">{{ 'footer.shipping' | t }}</a></li>
            {%- else -%}
              <li><span class="site-footer__static">{{ 'footer.shipping' | t }}</span></li>
            {%- endif -%}
            {%- if url_returns != blank -%}
              <li><a href="{{ url_returns }}">{{ 'footer.returns' | t }}</a></li>
            {%- else -%}
              <li><span class="site-footer__static">{{ 'footer.returns' | t }}</span></li>
            {%- endif -%}
            {%- if section.settings.link_care != blank -%}
              <li><a href="{{ section.settings.link_care }}">{{ 'footer.care_guide' | t }}</a></li>
            {%- else -%}
              <li><span class="site-footer__static">{{ 'footer.care_guide' | t }}</span></li>
            {%- endif -%}
            <li><a href="{{ section.settings.link_contact | default: '/pages/contact' }}">{{ 'footer.contact' | t }}</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="site-footer__bottom">
      {%- comment -%}
        Resolve each social from the footer section setting first, then fall back
        to the global theme "Social Media" settings (settings.*), so icons appear
        wherever the merchant entered them. WhatsApp falls back to the phone number.
      {%- endcomment -%}
      {%- liquid
        assign url_tiktok    = section.settings.social_tiktok    | default: settings.social_tiktok    | default: 'https://www.tiktok.com/@perfumers_eg'
        assign url_instagram = section.settings.social_instagram | default: settings.social_instagram | default: 'https://www.instagram.com/perfumers_eg'
        assign url_facebook  = section.settings.social_facebook  | default: settings.social_facebook
        assign wa_raw        = section.settings.social_whatsapp  | default: settings.social_whatsapp  | default: section.settings.phone | default: '01119112182'
      -%}
      <div class="site-footer__socials">
        {%- if url_tiktok != blank -%}
          <a href="{{ url_tiktok }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        {%- endif -%}
        {%- if url_instagram != blank -%}
          <a href="{{ url_instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        {%- endif -%}
        {%- if url_facebook != blank -%}
          <a href="{{ url_facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        {%- endif -%}
        {%- if wa_raw != blank -%}
          {%- assign wa_number = wa_raw | remove: '+' | remove: ' ' | remove: '-' | remove: '(' | remove: ')' -%}
          {%- if wa_number.size <= 11 -%}
            {%- assign wa_number = wa_number | slice: 1, 20 | prepend: '20' -%}
          {%- endif -%}
          <a href="https://wa.me/{{ wa_number }}?text=Hi%20Perfumers!%20I%27d%20like%20to%20ask%20about%20a%20fragrance." target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        {%- endif -%}
      </div>
      <p class="site-footer__copyright">
        {{ section.settings.copyright | default: "© 2026 PERFUMERS. All rights reserved." }}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: #E7DDD4; /* bg-pearl-beige */
    color: #2E2A33; /* dark text */
    padding-top: 6rem; /* pt-24 */
    padding-bottom: 3rem; /* pb-12 */
    padding-left: 2rem; /* px-8 */
    padding-right: 2rem;
    font-family: 'Montserrat', sans-serif;
  }

  .site-footer__container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem; /* gap-12 */
    margin-bottom: 4rem; /* mb-16 */
  }

  @media (min-width: 768px) {
    .site-footer__grid {
      grid-template-columns: 1.5fr 2fr;
    }
  }

  .site-footer__brand {
    display: flex;
    flex-direction: column;
  }

  .site-footer__logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; /* text-2xl */
    font-weight: 400;
    letter-spacing: 0.1em; /* tracking-[0.1em] */
    margin: 0 0 1.5rem 0; /* mb-6 */
    text-transform: uppercase;
    color: #2E2A33;
    line-height: 1.2;
  }

  .site-footer__description {
    font-size: 0.75rem; /* text-xs */
    line-height: 2; /* leading-loose */
    opacity: 0.6;
    font-weight: 300; /* font-light */
    max-width: 20rem; /* max-w-xs */
    margin: 0;
  }

  .site-footer__links-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem; /* gap-8 */
  }

  .site-footer__heading {
    font-size: 10px; /* text-[10px] */
    text-transform: uppercase;
    letter-spacing: 0.1em; /* tracking-widest */
    color: #C8A46A; /* text-primary */
    font-weight: 700;
    margin: 0 0 1rem 0; /* mb-4 */
  }

  .site-footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem; /* gap-3 */
  }

  .site-footer__list a {
    color: #2E2A33;
    text-decoration: none;
    font-size: 0.75rem; /* text-xs */
    opacity: 0.6;
    font-weight: 300; /* font-light */
    transition: opacity 0.3s ease;
  }

  .site-footer__list a:hover {
    opacity: 1;
  }

  .site-footer__static {
    color: #2E2A33;
    font-size: 0.75rem; /* text-xs */
    opacity: 0.45;
    font-weight: 300; /* font-light */
    cursor: default;
  }

  .site-footer__bottom {
    padding-top: 2rem; /* pt-8 */
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    gap: 1.5rem; /* gap-6 */
    align-items: center;
  }

  .site-footer__socials {
    display: flex;
    gap: 1.5rem; /* gap-6 */
    align-items: center;
  }

  .site-footer__socials a {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .site-footer__socials span {
    font-size: 1.25rem; /* text-sm */
    opacity: 0.5;
    transition: opacity 0.3s ease;
    cursor: pointer;
  }

  .site-footer__socials a:hover span {
    opacity: 1;
  }

  .site-footer__socials svg {
    width: 18px;
    height: 18px;
    opacity: 0.55;
    transition: opacity 0.3s ease;
    display: block;
  }

  .site-footer__socials a:hover svg {
    opacity: 1;
  }

  .site-footer__copyright {
    font-size: 9px; /* text-[9px] */
    opacity: 0.4;
    letter-spacing: 0.1em; /* tracking-widest */
    text-transform: uppercase;
    margin: 0;
    text-align: center;
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "about_text",
      "label": "About text",
      "default": "Premium fragrances, authentically sourced. Every scent delivered across Egypt."
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+201065833338"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "hello@perfumers.eg"
    },
    {
      "type": "text",
      "id": "location",
      "label": "Location",
      "default": "Cairo, Egypt"
    },
    {
      "type": "url",
      "id": "link_archive",
      "label": "The Archive link"
    },
    {
      "type": "url",
      "id": "link_authentication",
      "label": "Authentication link"
    },
    {
      "type": "url",
      "id": "link_story",
      "label": "Our Story link"
    },
    {
      "type": "url",
      "id": "link_shipping",
      "label": "Shipping link"
    },
    {
      "type": "url",
      "id": "link_returns",
      "label": "Returns link"
    },
    {
      "type": "url",
      "id": "link_care",
      "label": "Care Guide link"
    },
    {
      "type": "url",
      "id": "link_contact",
      "label": "Contact link"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "text",
      "id": "social_whatsapp",
      "label": "WhatsApp number",
      "info": "Digits with country code, e.g. 201065833338 (opens wa.me)."
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2026 PERFUMERS. All rights reserved."
    }
  ],
  "presets": [
    { "name": "Footer" }
  ]
}
{% endschema %}
