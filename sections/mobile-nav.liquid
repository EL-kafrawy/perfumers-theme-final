<nav class="mobile-bottom-nav">
  <a class="mobile-bottom-nav__item" href="{{ section.settings.home_link | default: '/' }}" data-nav-item="home">
    <span class="material-symbols-outlined">home</span>
    <span class="mobile-bottom-nav__label">Home</span>
  </a>
  <a class="mobile-bottom-nav__item" href="{{ section.settings.hot_sellers_link | default: '/collections/best-sellers' }}" data-nav-item="hot-sellers">
    <span class="material-symbols-outlined">local_fire_department</span>
    <span class="mobile-bottom-nav__label">Hot Sellers</span>
  </a>
  <a class="mobile-bottom-nav__item" href="{{ section.settings.gender_link | default: '/collections/all' }}" data-nav-item="gender">
    <span class="material-symbols-outlined">wc</span>
    <span class="mobile-bottom-nav__label">By Gender</span>
  </a>
  <a class="mobile-bottom-nav__item" href="{{ section.settings.brand_link | default: '/collections/all' }}" data-nav-item="brand">
    <span class="material-symbols-outlined">sell</span>
    <span class="mobile-bottom-nav__label">By Brand</span>
  </a>
</nav>
<div class="mobile-bottom-nav__spacer"></div>

<style>
  .mobile-bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: rgba(245, 241, 235, 0.97);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid rgba(200, 164, 106, 0.15);
    z-index: 50;
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 8px 0 max(12px, env(safe-area-inset-bottom));
  }

  .mobile-bottom-nav__spacer {
    height: 64px;
  }

  .mobile-bottom-nav__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    text-decoration: none;
    color: rgba(45, 41, 38, 0.4);
    transition: color 0.2s ease;
    padding: 4px 12px;
    min-width: 60px;
  }

  .mobile-bottom-nav__item .material-symbols-outlined {
    font-size: 22px;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
  }

  .mobile-bottom-nav__label {
    font-family: var(--font-sans, 'Montserrat', sans-serif);
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    line-height: 1;
  }

  .mobile-bottom-nav__item:hover,
  .mobile-bottom-nav__item.is-active {
    color: #C8A46A;
  }

  .mobile-bottom-nav__item.is-active .material-symbols-outlined {
    font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }

  @media (min-width: 768px) {
    .mobile-bottom-nav,
    .mobile-bottom-nav__spacer {
      display: none;
    }
  }
</style>

<script>
  (function() {
    var path = window.location.pathname;
    document.querySelectorAll('.mobile-bottom-nav__item').forEach(function(item) {
      var href = item.getAttribute('href');
      if (href === '/' ? path === '/' : path.indexOf(href) === 0) {
        item.classList.add('is-active');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Mobile Bottom Nav",
  "settings": [
    {
      "type": "url",
      "id": "home_link",
      "label": "Home link"
    },
    {
      "type": "url",
      "id": "hot_sellers_link",
      "label": "Hot Sellers link",
      "info": "e.g. /collections/best-sellers"
    },
    {
      "type": "url",
      "id": "gender_link",
      "label": "Shop by Gender link",
      "info": "e.g. /collections/all"
    },
    {
      "type": "url",
      "id": "brand_link",
      "label": "Shop by Brand link",
      "info": "e.g. /collections/all"
    }
  ],
  "presets": [
    { "name": "Mobile Bottom Nav" }
  ]
}
{% endschema %}
