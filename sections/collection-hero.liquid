{%- comment -%}
  Banner image priority: the collection's own image (set in Shopify admin) first.
  If none is set, fall back to a real local theme asset by gender handle so the
  banner is never a broken image.
{%- endcomment -%}
{%- assign collection_image = collection.image -%}
{%- assign fallback_image = '' -%}
{%- if collection_image == blank -%}
  {%- if collection.handle == 'unisex' -%}
    {%- assign fallback_image = 'unisex.webp' | asset_url -%}
  {%- elsif collection.handle == 'men' -%}
    {%- assign fallback_image = 'men.jpg' | asset_url -%}
  {%- elsif collection.handle == 'women' -%}
    {%- assign fallback_image = 'women.jpg' | asset_url -%}
  {%- endif -%}
{%- endif -%}

{%- assign show_overlay_and_text = true -%}
{%- if collection.handle == 'unisex' or collection.handle == 'men' or collection.handle == 'women' -%}
  {%- assign show_overlay_and_text = false -%}
{%- endif -%}

<section class="collection-hero section--flush" data-section-id="{{ section.id }}">
  <div class="collection-hero__wrapper">
    {%- if collection_image != blank -%}
      <img
        src="{{ collection_image | image_url: width: 1440 }}"
        alt="{{ collection.title | escape }}"
        class="collection-hero__image"
        width="1440"
        height="640"
        loading="eager"
      >
    {%- elsif fallback_image != blank -%}
      <img
        src="{{ fallback_image }}"
        alt="{{ collection.title | escape }}"
        class="collection-hero__image"
        width="1440"
        height="640"
        loading="eager"
      >
    {%- else -%}
      <div class="collection-hero__image collection-hero__placeholder"></div>
    {%- endif -%}
    
    {%- if show_overlay_and_text -%}
      <div class="collection-hero__overlay"></div>
      <div class="collection-hero__content">
        <div class="container">
          {% render 'breadcrumb' %}
          <h1 class="collection-hero__title">{{ collection.title }}</h1>
          {%- if collection.description != blank -%}
            <p class="collection-hero__description">{{ collection.description | strip_html | truncate: 160 }}</p>
          {%- endif -%}
          <p class="collection-hero__count">{{ collection.products_count }} {{ 'collection.products_count' | t: count: collection.products_count }}</p>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .collection-hero__wrapper {
    position: relative;
    min-height: 240px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .collection-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .collection-hero__placeholder {
    background: linear-gradient(135deg, var(--color-mauve) 0%, var(--color-charcoal) 100%);
  }
  .collection-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--color-charcoal-80) 0%, rgba(46, 42, 51, 0.3) 100%);
  }
  .collection-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: var(--space-2xl) 0;
  }
  .collection-hero__title {
    color: var(--color-ivory);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
  }
  .collection-hero__description {
    color: var(--color-pearl);
    font-size: var(--text-sm);
    max-width: 600px;
    margin-bottom: var(--space-sm);
  }
  .collection-hero__count {
    color: var(--color-mauve);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  @media (min-width: 768px) {
    .collection-hero__wrapper { min-height: 320px; }
    .collection-hero__title { font-size: var(--text-3xl); }
  }
</style>

{% schema %}
{
  "name": "Collection Hero",
  "settings": [],
  "presets": [
    {
      "name": "Collection Hero"
    }
  ]
}
{% endschema %}
