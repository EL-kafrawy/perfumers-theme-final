<section class="product-gallery section--flush" data-section-id="{{ section.id }}">
  <div class="product-gallery__wrapper" data-product-gallery>
    <!-- Main Image -->
    <div class="product-gallery__main">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 800 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          class="product-gallery__main-image"
          data-product-main-image
          width="800"
          height="1067"
          loading="eager"
        >
      {%- else -%}
        <div class="product-gallery__main-image placeholder-image" style="aspect-ratio:3/4;">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {%- endif -%}

      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__badge product-card__badge--sale">{{ 'product.sale' | t }}</span>
      {%- endif -%}
    </div>

    <!-- Thumbnails -->
    {%- if product.images.size > 1 -%}
      <div class="product-gallery__thumbs scroll-row">
        {%- for image in product.images -%}
          <button
            class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
            data-product-thumbnail
            data-full-src="{{ image | image_url: width: 800 }}"
            aria-label="View image {{ forloop.index }}"
          >
            <img
              src="{{ image | image_url: width: 120 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="80"
              height="100"
            >
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  /* ---- Gallery Component ---- */
  .product-gallery__wrapper {
    background: var(--color-surface);
  }
  .product-gallery__main {
    position: relative;
    overflow: hidden;
  }
  .product-gallery__main-image {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
    max-height: 70vh;
  }
  @media (min-width: 1024px) {
    .product-gallery__main-image {
      max-height: calc(100vh - 180px);
    }
  }
  .product-gallery__thumbs {
    padding: var(--space-md);
    gap: var(--space-sm);
  }
  .product-gallery__thumb {
    flex: 0 0 64px;
    width: 64px;
    height: 80px;
    overflow: hidden;
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    background: none;
    padding: 0;
    transition: border-color var(--transition-fast);
  }
  .product-gallery__thumb.is-active {
    border-color: var(--color-gold);
  }
  .product-gallery__thumb:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 3px;
    border-color: var(--color-gold);
  }
  .product-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Desktop: gallery wrapper switches to vertical thumb strip */
  @media (min-width: 1024px) {
    .product-gallery .product-gallery__wrapper {
      display: flex;
      flex-direction: row-reverse;
      gap: var(--space-md);
    }
    .product-gallery__main { flex: 1; }
    .product-gallery__thumbs {
      flex-direction: column;
      overflow-y: auto;
      overflow-x: hidden;
      max-height: 600px;
      width: 80px;
    }
    .product-gallery__thumb { flex: 0 0 80px; width: 80px; height: 100px; }
  }
</style>

{% schema %}
{
  "name": "Product Gallery",
  "settings": [],
  "presets": [
    {
      "name": "Product Gallery"
    }
  ]
}
{% endschema %}
