<section class="best-sellers section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="section__header" data-animate>
      <span class="section__accent">{{ section.settings.accent_text }}</span>
      <h2 class="section__title">{%- if section.settings.title != blank -%}{{ section.settings.title }}{%- else -%}{{ 'sections.best_sellers.title' | t }}{%- endif -%}</h2>
      <p class="section__subtitle">{%- if section.settings.subtitle != blank -%}{{ section.settings.subtitle }}{%- else -%}{{ 'sections.best_sellers.subtitle' | t }}{%- endif -%}</p>
      <div class="divider"></div>
    </div>

    <div class="scroll-row best-sellers__row">
      {%- if section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_limit -%}
          <div class="best-sellers__item">
            {% render 'product-card', product: product, badge: 'best_seller' %}
          </div>
        {%- endfor -%}
      {%- else -%}
        <p class="best-sellers__empty" style="text-align:center;color:var(--color-text-secondary);font-size:var(--text-sm);padding:var(--space-xl) 0;">Assign a collection in the theme editor to display products here.</p>
      {%- endif -%}
    </div>

    {%- if section.settings.view_all_link != blank -%}
      <div class="text-center mt-xl">
        <a href="{{ section.settings.view_all_link }}" class="btn btn-secondary btn-small">{{ 'actions.view_all' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .best-sellers__item {
    flex: 0 0 260px;
    max-width: 260px;
  }
  @media (min-width: 768px) {
    .best-sellers__row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-xl);
      overflow: visible;
    }
    .best-sellers__item {
      flex: none;
      max-width: none;
    }
  }
</style>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    {
      "type": "text",
      "id": "accent_text",
      "label": "Accent text",
      "default": "Popular"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Most loved fragrances"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    }
  ],
  "presets": [
    {
      "name": "Best Sellers"
    }
  ]
}
{% endschema %}
