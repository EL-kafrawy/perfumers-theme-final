<!-- A11y: role=dialog + aria-label + aria-modal for screen readers -->
<div class="mobile-menu drawer" data-mobile-menu role="dialog" aria-label="Mobile navigation menu" aria-modal="true">
  <!-- Menu Header -->
  <div class="mobile-menu__header">
    <div class="mobile-menu__title">{{ section.settings.menu_title | default: "Aromatic Journey" }}</div>
    <!-- A11y: descriptive aria-label for close button -->
    <button class="mobile-menu__close-btn" data-mobile-menu-close aria-label="Close mobile menu">
      <span class="material-symbols-outlined">close</span>
    </button>
  </div>

  <!-- Menu Body -->
  <div class="mobile-menu__body">
    <!-- Links List -->
    <nav class="mobile-menu__nav" role="navigation" aria-label="Mobile navigation">
      <ul class="mobile-menu__list">
        {%- if section.settings.menu.links.size > 0 -%}
          {%- for link in section.settings.menu.links -%}
            <li class="mobile-menu__link-item">
              <a class="mobile-menu__link group" href="{{ link.url }}">
                <span class="mobile-menu__link-text">{{ link.title }}</span>
                <span class="material-symbols-outlined mobile-menu__link-arrow">arrow_forward_ios</span>
              </a>
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} No Shopify menu assigned — show the four core nav destinations. {%- endcomment -%}
          <li class="mobile-menu__link-item">
            <a class="mobile-menu__link" href="/">
              <span class="mobile-menu__link-text">Home</span>
              <span class="material-symbols-outlined mobile-menu__link-arrow">arrow_forward_ios</span>
            </a>
          </li>
          <li class="mobile-menu__link-item">
            <a class="mobile-menu__link" href="/collections/hot-sellers">
              <span class="mobile-menu__link-text">Hot Sellers</span>
              <span class="material-symbols-outlined mobile-menu__link-arrow">arrow_forward_ios</span>
            </a>
          </li>
          <li class="mobile-menu__link-item">
            <a class="mobile-menu__link" href="/collections/all">
              <span class="mobile-menu__link-text">Shop by Gender</span>
              <span class="material-symbols-outlined mobile-menu__link-arrow">arrow_forward_ios</span>
            </a>
          </li>
          <li class="mobile-menu__link-item">
            <a class="mobile-menu__link" href="/collections/all">
              <span class="mobile-menu__link-text">Shop by Brand</span>
              <span class="material-symbols-outlined mobile-menu__link-arrow">arrow_forward_ios</span>
            </a>
          </li>
        {%- endif -%}
      </ul>
    </nav>

    <!-- Divider with Accent -->
    <div class="mobile-menu__divider">
      <div class="mobile-menu__divider-line"></div>
      <span class="mobile-menu__divider-text">{{ section.settings.divider_text | default: "Curated Selection" }}</span>
    </div>

    <!-- Featured Highlight Section -->
    {%- assign featured_img_url = 'discovery-set.jpg' | asset_url -%}
    {%- if section.settings.featured_image != blank -%}
      {%- assign featured_img_url = section.settings.featured_image | image_url: width: 300 -%}
    {%- elsif section.settings.featured_product != blank and section.settings.featured_product.featured_image != blank -%}
      {%- assign featured_img_url = section.settings.featured_product.featured_image | image_url: width: 300 -%}
    {%- endif -%}

    {%- assign featured_title = section.settings.featured_title -%}
    {%- if featured_title == blank and section.settings.featured_product != blank -%}
      {%- assign featured_title = section.settings.featured_product.title -%}
    {%- endif -%}

    {%- assign featured_url = section.settings.featured_url -%}
    {%- if featured_url == blank and section.settings.featured_product != blank -%}
      {%- assign featured_url = section.settings.featured_product.url -%}
    {%- endif -%}

    <a href="{{ featured_url | default: routes.all_products_collection_url }}" class="mobile-menu__featured">
      <div class="mobile-menu__featured-img" style="background-image: url('{{ featured_img_url }}');" aria-label="{{ featured_title | default: 'Featured highlight' }}"></div>
      <div class="mobile-menu__featured-content">
        <h4 class="mobile-menu__featured-tagline">{{ section.settings.featured_tagline | default: "Featured Set" }}</h4>
        <p class="mobile-menu__featured-title">{{ featured_title | default: "The Discovery Kit" }}</p>
        <p class="mobile-menu__featured-desc">{{ section.settings.featured_desc | default: "Twelve poetic journeys in glass." }}</p>
      </div>
      <span class="material-symbols-outlined mobile-menu__featured-arrow">chevron_right</span>
    </a>

    <!-- Footer Links Grid -->
    <div class="mobile-menu__footer-grid">
<a href="{{ routes.cart_url }}" class="mobile-menu__footer-btn">
        <span class="material-symbols-outlined mobile-menu__footer-icon">shopping_bag</span>
        <span class="mobile-menu__footer-text">{{ 'navigation.cart' | t }}
          <span class="cart-count" data-cart-count aria-label="Cart items"></span>
        </span>
      </a>
      <a href="{{ section.settings.support_url | default: '/pages/contact' }}" class="mobile-menu__footer-btn">
        <span class="material-symbols-outlined mobile-menu__footer-icon">help_outline</span>
        <span class="mobile-menu__footer-text">Support</span>
      </a>
    </div>
  </div>

  <!-- Bottom Brand Mark -->
  <div class="mobile-menu__brand-mark">
    <span class="mobile-menu__brand-mark-text">{{ section.settings.brand_mark | default: "Est. 1924 • Paris • Grasse" }}</span>
  </div>
</div>
<div class="overlay" data-mobile-menu-overlay></div>

<style>
  /* Slide in from LEFT (override shared .drawer base which defaults to right) */
  .mobile-menu.drawer {
    right: auto;
    left: 0;
    transform: translateX(-100%);
  }

  .mobile-menu.drawer.is-open {
    transform: translateX(0);
  }

  /* Scoped Mobile Menu Drawer overrides */
  .mobile-menu.drawer {
    background-color: #f8f7f6;
    color: var(--color-charcoal, #2E2A33);
    display: flex;
    flex-direction: column;
    z-index: 1000;
    overflow: hidden; /* let .mobile-menu__body handle scroll, not the drawer root */
    height: 100%;
  }

  .mobile-menu__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem;
    border-bottom: 1px solid rgba(198, 163, 108, 0.15); /* Primary gold border low opacity */
    flex-shrink: 0;
  }

  .mobile-menu__title {
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    font-size: 1.25rem;
    font-style: italic;
    color: #c6a36c; /* Champagne Gold from Stitch */
    font-weight: 400;
    letter-spacing: 0.05em;
  }

  .mobile-menu__close-btn {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full, 9999px);
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-charcoal, #2E2A33);
    transition: background-color 200ms ease, color 200ms ease;
  }

  .mobile-menu__close-btn:hover {
    background-color: rgba(198, 163, 108, 0.1);
    color: #c6a36c;
  }

  .mobile-menu__close-btn .material-symbols-outlined {
    font-size: 24px;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
  }

  .mobile-menu__body {
    flex: 1;
    overflow-y: auto;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    -webkit-overflow-scrolling: touch;
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
  }

  .mobile-menu__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-menu__link-item {
    display: block;
  }

  .mobile-menu__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    text-decoration: none;
    color: var(--color-charcoal, #2E2A33);
    transition: color 200ms ease;
    border: none;
    background: transparent;
    text-align: left;
    width: 100%;
  }

  .mobile-menu__link:hover {
    color: #c6a36c;
  }

  .mobile-menu__link-text {
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    font-size: 1.875rem; /* text-3xl from Stitch */
    font-weight: 300;
    line-height: 1.2;
    transition: transform 200ms ease;
  }

  .mobile-menu__link:hover .mobile-menu__link-text {
    transform: translateX(4px);
  }

  .mobile-menu__link-arrow {
    color: rgba(198, 163, 108, 0.4);
    transition: color 200ms ease, transform 200ms ease;
    font-size: 18px;
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }

  .mobile-menu__link:hover .mobile-menu__link-arrow {
    color: #c6a36c;
    transform: translateX(2px);
  }

  /* Divider with Accent */
  .mobile-menu__divider {
    position: relative;
    padding: 1rem 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .mobile-menu__divider-line {
    position: absolute;
    left: 0;
    right: 0;
    border-top: 1px solid rgba(198, 163, 108, 0.2);
    z-index: 1;
  }

  .mobile-menu__divider-text {
    position: relative;
    z-index: 2;
    background-color: #f8f7f6; /* Matching Soft Ivory */
    padding: 0 1rem;
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 1.125rem; /* text-lg */
    color: #c6a36c;
  }

  /* Featured Highlight Section */
  .mobile-menu__featured {
    display: flex;
    align-items: center;
    gap: 1rem;
    background-color: rgba(198, 163, 108, 0.05); /* bg-primary/5 */
    border: 1px solid rgba(198, 163, 108, 0.15); /* border-primary/10 */
    border-radius: 0.75rem; /* rounded-xl */
    padding: 1rem;
    text-decoration: none;
    color: var(--color-charcoal, #2E2A33);
    transition: border-color 250ms ease, transform 250ms ease, background-color 250ms ease;
    flex-shrink: 0;
  }

  .mobile-menu__featured:hover {
    border-color: rgba(198, 163, 108, 0.35);
    background-color: rgba(198, 163, 108, 0.08);
    transform: translateY(-2px);
  }

  .mobile-menu__featured-img {
    width: 5rem; /* size-20 */
    height: 5rem;
    border-radius: 0.5rem; /* rounded-lg */
    background-size: cover;
    background-position: center;
    border: 1px solid rgba(198, 163, 108, 0.2);
    flex-shrink: 0;
  }

  .mobile-menu__featured-content {
    flex: 1;
    min-width: 0;
  }

  .mobile-menu__featured-tagline {
    font-family: var(--font-sans, 'Montserrat', sans-serif);
    font-weight: 600;
    font-size: 0.65rem; /* text-xs */
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #c6a36c;
    margin: 0 0 0.25rem 0;
  }

  .mobile-menu__featured-title {
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    font-size: 1.25rem; /* text-xl */
    color: var(--color-charcoal, #2E2A33);
    margin: 0 0 0.15rem 0;
    font-weight: 400;
    line-height: 1.2;
  }

  .mobile-menu__featured-desc {
    font-family: var(--font-sans, 'Montserrat', sans-serif);
    font-size: 0.7rem; /* text-xs */
    color: var(--color-taupe, #7E6C5F);
    margin: 0;
    line-height: 1.3;
  }

  .mobile-menu__featured-arrow {
    color: #c6a36c;
    font-size: 24px;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
    transition: transform 200ms ease;
  }

  .mobile-menu__featured:hover .mobile-menu__featured-arrow {
    transform: translateX(2px);
  }

  /* Footer Links Grid — flex so it looks right with 2 or 3 buttons */
  .mobile-menu__footer-grid {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .mobile-menu__footer-grid > .mobile-menu__footer-btn {
    flex: 1 1 0;
  }

  .mobile-menu__footer-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background-color: var(--color-pearl, #E7DDD4); /* pearl beige backdrop */
    border: 1px solid rgba(46, 42, 51, 0.1);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--color-charcoal, #2E2A33);
    transition: background-color 200ms ease, border-color 200ms ease;
  }

  .mobile-menu__footer-btn:hover {
    background-color: rgba(198, 163, 108, 0.1);
    border-color: rgba(198, 163, 108, 0.35);
  }

  .mobile-menu__footer-icon {
    color: #c6a36c;
    font-size: 20px;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
  }

  .mobile-menu__footer-text {
    font-family: var(--font-sans, 'Montserrat', sans-serif);
    font-weight: 500;
    font-size: 0.85rem; /* text-sm */
  }

  /* Bottom Brand Mark */
  .mobile-menu__brand-mark {
    margin-top: auto;
    padding: 2rem 1.5rem;
    text-align: center;
    opacity: 0.4;
    flex-shrink: 0;
  }

  .mobile-menu__brand-mark-text {
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 0.8rem; /* text-sm */
    letter-spacing: 0.15em;
    color: var(--color-charcoal, #2E2A33);
  }

  /* A11y adjustments & overlay override */
  @media (min-width: 1024px) {
    .mobile-menu.drawer,
    [data-mobile-menu-overlay] {
      display: none !important;
    }
  }
</style>

{% schema %}
{
  "name": "Mobile Menu",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "menu_title",
      "label": "Menu Title",
      "default": "Aromatic Journey"
    },
    {
      "type": "text",
      "id": "divider_text",
      "label": "Divider Text",
      "default": "Curated Selection"
    },
    {
      "type": "header",
      "content": "Featured Highlight Section"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product"
    },
    {
      "type": "text",
      "id": "featured_tagline",
      "label": "Featured Tagline",
      "default": "Featured Set"
    },
    {
      "type": "text",
      "id": "featured_title",
      "label": "Featured Title",
      "default": "The Discovery Kit",
      "info": "Leave blank to use selected product's title."
    },
    {
      "type": "text",
      "id": "featured_desc",
      "label": "Featured Description",
      "default": "Twelve poetic journeys in glass."
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Featured Custom Image",
      "info": "Leave blank to use product image or discovery-set asset image."
    },
    {
      "type": "url",
      "id": "featured_url",
      "label": "Featured Custom URL",
      "info": "Leave blank to use product page URL."
    },
    {
      "type": "header",
      "content": "Footer Buttons & Brand"
    },
    {
      "type": "url",
      "id": "support_url",
      "label": "Support Link",
      "info": "Link to support/contact page."
    },
    {
      "type": "text",
      "id": "brand_mark",
      "label": "Brand Mark Text",
      "default": "Est. 1924 • Paris • Grasse"
    }
  ]
}
{% endschema %}
