<style>
  .quiz-wrap { max-width:600px; margin:60px auto; padding:0 20px; font-family:inherit; }
  .quiz-step { display:none; }
  .quiz-step.active { display:block; }
  .quiz-wrap h1 { font-size:28px; letter-spacing:0.08em; text-align:center; margin-bottom:8px; }
  .quiz-wrap .quiz-subtitle { text-align:center; color:#777; font-size:14px; margin-bottom:40px; }
  .quiz-wrap h2 { font-size:18px; letter-spacing:0.05em; margin-bottom:24px; text-align:center; }
  .quiz-options { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:32px; }
  .quiz-option {
    border:2px solid #e0e0e0; border-radius:10px; padding:20px 16px;
    text-align:center; cursor:pointer; transition:all 0.2s;
    font-size:14px; font-weight:600; letter-spacing:0.04em;
    background:#fff; color:#1a1a1a;
  }
  .quiz-option:hover, .quiz-option.selected { border-color:#1a1a1a; background:#1a1a1a; color:#fff; }
  .quiz-option .opt-emoji { font-size:28px; display:block; margin-bottom:8px; }
  .quiz-progress { display:flex; gap:6px; justify-content:center; margin-bottom:40px; }
  .quiz-progress span { width:28px; height:4px; background:#e0e0e0; border-radius:2px; transition:background 0.3s; }
  .quiz-progress span.done { background:#1a1a1a; }
  .quiz-result { text-align:center; display:none; }
  .quiz-result.active { display:block; }
  .result-card { border:1px solid #e0e0e0; border-radius:12px; padding:32px; margin:24px 0; background:#fafafa; }
  .result-card h3 { font-size:22px; margin-bottom:8px; }
  .result-card p { color:#555; font-size:14px; line-height:1.7; margin-bottom:20px; }
  .result-cta { display:inline-block; background:#1a1a1a; color:#fff; padding:12px 32px; border-radius:6px; font-size:13px; font-weight:700; letter-spacing:0.08em; text-decoration:none; }
  .result-cta:hover { background:#333; }
  .quiz-restart { display:inline-block; margin-top:16px; font-size:13px; color:#888; cursor:pointer; text-decoration:underline; background:none; border:none; }
</style>

<div class="quiz-wrap">
  <h1>FIND YOUR SCENT</h1>
  <p class="quiz-subtitle">3 quick questions. Your perfect fragrance awaits.</p>

  <div class="quiz-progress">
    <span id="p1" class="done"></span>
    <span id="p2"></span>
    <span id="p3"></span>
  </div>

  <!-- Step 1: Who are you shopping for? -->
  <div class="quiz-step active" id="step-1">
    <h2>Who are you shopping for?</h2>
    <div class="quiz-options">
      <div class="quiz-option" data-answer="men" onclick="quizSelect(this, 1)">
        <span class="opt-emoji">🧔</span> Men
      </div>
      <div class="quiz-option" data-answer="women" onclick="quizSelect(this, 1)">
        <span class="opt-emoji">👩</span> Women
      </div>
      <div class="quiz-option" data-answer="unisex" onclick="quizSelect(this, 1)">
        <span class="opt-emoji">🌟</span> Unisex
      </div>
      <div class="quiz-option" data-answer="gift" onclick="quizSelect(this, 1)">
        <span class="opt-emoji">🎁</span> A Gift
      </div>
    </div>
  </div>

  <!-- Step 2: What vibe are you after? -->
  <div class="quiz-step" id="step-2">
    <h2>What vibe are you after?</h2>
    <div class="quiz-options">
      <div class="quiz-option" data-answer="fresh" onclick="quizSelect(this, 2)">
        <span class="opt-emoji">🍋</span> Fresh & Clean
      </div>
      <div class="quiz-option" data-answer="warm" onclick="quizSelect(this, 2)">
        <span class="opt-emoji">🔥</span> Warm & Spicy
      </div>
      <div class="quiz-option" data-answer="sweet" onclick="quizSelect(this, 2)">
        <span class="opt-emoji">🍯</span> Sweet & Gourmand
      </div>
      <div class="quiz-option" data-answer="woody" onclick="quizSelect(this, 2)">
        <span class="opt-emoji">🌲</span> Woody & Earthy
      </div>
    </div>
  </div>

  <!-- Step 3: When do you wear it? -->
  <div class="quiz-step" id="step-3">
    <h2>When will you wear it?</h2>
    <div class="quiz-options">
      <div class="quiz-option" data-answer="daily" onclick="quizSelect(this, 3)">
        <span class="opt-emoji">☀️</span> Everyday
      </div>
      <div class="quiz-option" data-answer="evening" onclick="quizSelect(this, 3)">
        <span class="opt-emoji">🌙</span> Evening / Date Night
      </div>
      <div class="quiz-option" data-answer="office" onclick="quizSelect(this, 3)">
        <span class="opt-emoji">💼</span> Office / Professional
      </div>
      <div class="quiz-option" data-answer="special" onclick="quizSelect(this, 3)">
        <span class="opt-emoji">✨</span> Special Occasions
      </div>
    </div>
  </div>

  <!-- Result -->
  <div class="quiz-result" id="quiz-result">
    <h2>Your Fragrance Match</h2>
    <div class="result-card" id="result-card">
      <h3 id="result-title"></h3>
      <p id="result-desc"></p>
      <a href="/collections/all" class="result-cta" id="result-link">SHOP THIS STYLE</a>
    </div>
    <button class="quiz-restart" onclick="quizRestart()">Take the quiz again</button>
  </div>
</div>

<script>
var quizAnswers = {};

function quizSelect(el, step) {
  // Mark selected
  var options = el.parentElement.querySelectorAll('.quiz-option');
  options.forEach(function(o){ o.classList.remove('selected'); });
  el.classList.add('selected');
  quizAnswers['step' + step] = el.getAttribute('data-answer');

  setTimeout(function(){
    if (step < 3) {
      // Next step
      document.getElementById('step-' + step).classList.remove('active');
      document.getElementById('step-' + (step + 1)).classList.add('active');
      document.getElementById('p' + (step + 1)).classList.add('done');
    } else {
      // Show result
      document.getElementById('step-3').classList.remove('active');
      showResult();
    }
  }, 300);
}

function showResult() {
  var vibe = quizAnswers.step2 || 'fresh';
  var occasion = quizAnswers.step3 || 'daily';

  var results = {
    'fresh': {
      title: 'Fresh & Citrus Collection',
      desc: 'You love clean, invigorating scents. Think crisp citrus, aquatic notes, and green freshness — perfect for energizing your day.',
      link: '/collections/all?filter.p.tag=fresh'
    },
    'warm': {
      title: 'Warm & Spicy Collection',
      desc: 'You gravitate toward rich, bold fragrances. Expect cinnamon, cardamom, saffron, and amber — scents that leave a lasting impression.',
      link: '/collections/all?filter.p.tag=warm'
    },
    'sweet': {
      title: 'Sweet & Gourmand Collection',
      desc: 'You have a taste for indulgent sweetness. Think vanilla, caramel, tonka bean, and praline — irresistibly cozy and addictive.',
      link: '/collections/all?filter.p.tag=sweet'
    },
    'woody': {
      title: 'Woody & Earthy Collection',
      desc: 'You appreciate grounded, natural elegance. Sandalwood, oud, vetiver, and cedarwood — timeless and sophisticated.',
      link: '/collections/all?filter.p.tag=woody'
    }
  };

  var match = results[vibe] || results['fresh'];

  document.getElementById('result-title').textContent = match.title;
  document.getElementById('result-desc').textContent = match.desc;
  document.getElementById('result-link').href = match.link;
  document.getElementById('quiz-result').classList.add('active');
}

function quizRestart() {
  quizAnswers = {};
  document.getElementById('quiz-result').classList.remove('active');
  document.querySelectorAll('.quiz-step').forEach(function(s){ s.classList.remove('active'); });
  document.querySelectorAll('.quiz-option').forEach(function(o){ o.classList.remove('selected'); });
  document.getElementById('step-1').classList.add('active');
  document.getElementById('p2').classList.remove('done');
  document.getElementById('p3').classList.remove('done');
}
</script>

{% schema %}
{
  "name": "Fragrance Finder Quiz",
  "settings": [],
  "presets": [
    {
      "name": "Fragrance Finder Quiz"
    }
  ]
}
{% endschema %}
