<div class="filter-drawer drawer" data-filter-drawer data-section-id="{{ section.id }}">
  <div class="drawer__header">
    <h3 class="drawer__title">{{ 'collection.filter_by' | t }}</h3>
    <button class="drawer__close" data-filter-close aria-label="{{ 'actions.close' | t }}">
      {% render 'icon-close' %}
    </button>
  </div>

  <div class="drawer__body">
    <form data-filter-form>
      {%- for filter in collection.filters -%}
        <div class="filter-group" data-filter-group>
          <button class="filter-group__toggle" data-filter-group-toggle type="button">
            <span>{{ filter.label }}</span>
            {% render 'icon-arrow' %}
          </button>
          <div class="filter-group__options">
            {%- for value in filter.values -%}
              <label class="filter-group__option">
                <input
                  type="checkbox"
                  name="{{ filter.param_name }}"
                  value="{{ value.value }}"
                  data-filter-checkbox
                  {% if value.active %}checked{% endif %}
                >
                <span class="filter-group__label">{{ value.label }}</span>
                <span class="filter-group__count">({{ value.count }})</span>
              </label>
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </form>
  </div>

  <div class="drawer__footer">
    <div class="filter-drawer__actions">
      <button class="btn btn-secondary btn-small" data-filter-clear>{{ 'collection.clear_filters' | t }}</button>
      <button class="btn btn-primary btn-small" data-filter-apply>{{ 'collection.apply_filters' | t }}</button>
    </div>
  </div>
</div>
<div class="overlay" data-filter-overlay></div>

<style>
  .filter-group {
    border-bottom: 1px solid var(--color-pearl);
    padding: var(--space-md) 0;
  }
  .filter-group__toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-charcoal);
    padding: var(--space-sm) 0;
    cursor: pointer;
  }
  .filter-group__toggle svg {
    transition: transform var(--transition-fast);
  }
  .filter-group.is-collapsed .filter-group__toggle svg {
    transform: rotate(180deg);
  }
  .filter-group.is-collapsed .filter-group__options {
    display: none;
  }
  .filter-group__options {
    padding: var(--space-sm) 0;
  }
  .filter-group__option {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) 0;
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    cursor: pointer;
  }
  .filter-group__option input[type="checkbox"] {
    accent-color: var(--color-gold);
    width: 16px;
    height: 16px;
  }
  .filter-group__count {
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
  }
  .filter-drawer__actions {
    display: flex;
    gap: var(--space-sm);
  }
  .filter-drawer__actions .btn {
    flex: 1;
  }
</style>

{% schema %}
{
  "name": "Filter Drawer",
  "settings": [],
  "presets": [
    {
      "name": "Filter Drawer"
    }
  ]
}
{% endschema %}
