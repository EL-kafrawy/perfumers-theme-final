<section class="story-section" data-section-id="{{ section.id }}">
  <div class="story-hero">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.title }}" class="story-hero-img">
    {% else %}
      <div class="story-hero-placeholder" style="background: linear-gradient(135deg, var(--color-charcoal, #2E2A33) 0%, var(--color-accent, #B8A3AD) 100%);"></div>
    {% endif %}
    <div class="story-hero-overlay">
      <h1 class="story-hero-title serif-font">{{ section.settings.title }}</h1>
    </div>
  </div>

  <div class="container container--narrow">
    <div class="story-content-wrapper">
      <div class="story-text-block text-center rte">
        {{ section.settings.content }}
      </div>

      {% if section.settings.quote != blank %}
        <div class="story-quote text-center">
          <span class="material-symbols-outlined quote-icon">format_quote</span>
          <blockquote class="serif-font">{{ section.settings.quote }}</blockquote>
          {% if section.settings.author != blank %}
            <cite>— {{ section.settings.author }}</cite>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .story-section {
    padding-bottom: var(--space-4xl);
  }
  .story-hero {
    position: relative;
    height: 60vh;
    min-height: 400px;
    width: 100%;
    overflow: hidden;
    margin-bottom: var(--space-4xl);
  }
  .story-hero-img, 
  .story-hero-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-size: cover;
    background-position: center;
  }
  .story-hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(46, 42, 51, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .story-hero-title {
    color: var(--color-background);
    font-size: clamp(2.5rem, 8vw, 5rem);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-align: center;
    text-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }
  .story-content-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-4xl);
  }
  .story-text-block {
    font-size: var(--text-lg);
    line-height: var(--line-height-relaxed);
    color: var(--color-charcoal);
  }
  .story-quote {
    padding: var(--space-2xl);
    border: 1px solid var(--color-gold-20);
    position: relative;
    background-color: var(--color-surface);
  }
  .quote-icon {
    font-size: 40px;
    color: var(--color-gold);
    margin-bottom: var(--space-md);
  }
  .story-quote blockquote {
    font-size: var(--text-2xl);
    font-style: italic;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
  }
  .story-quote cite {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    font-weight: var(--font-semibold);
  }
</style>

{% schema %}
{
  "name": "Story Content",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Hero Title",
      "default": "Our Heritage"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Story Content",
      "default": "<p>Perfumers was born from a passion for timeless elegance and the art of fine scent. Our journey began in the vibrant heart of Cairo, where secrets of the past meet the dreams of tomorrow.</p>"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "A fragrance is the most intense form of memory."
    },
    {
      "type": "text",
      "id": "author",
      "label": "Quote Author",
      "default": "Founder"
    }
  ]
}
{% endschema %}
