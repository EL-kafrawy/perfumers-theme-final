<section class="relative min-h-[70vh] flex flex-col justify-center items-center text-center px-6 overflow-hidden pt-4 bg-[#F5F1EB]" style="background-color: #F5F1EB;">
  <div class="absolute inset-0 z-0">
    {%- if section.settings.image != blank -%}
      <img class="w-full h-full object-cover opacity-70 mix-blend-multiply" src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.image_alt | escape }}" width="2000" height="1400" style="object-position: {{ section.settings.image_position | default: 'center center' }};">
    {%- endif -%}
    <div class="absolute inset-0 bg-gradient-to-b from-soft-ivory/20 via-soft-ivory/40 to-soft-ivory"></div>
  </div>
  <div class="relative z-10 max-w-xl flex flex-col items-center">
    {%- if section.settings.accent_text != blank -%}
      <span class="text-[9px] uppercase tracking-[0.5em] text-primary mb-4 block font-semibold font-display">{{ section.settings.accent_text }}</span>
    {%- endif -%}
    <h2 class="mb-6 leading-[1.2] tracking-tight hero-heading" style="font-family: 'Cormorant Garamond', serif; font-weight: 300; color: #2E2A33; font-style: normal;">{{ section.settings.heading }}</h2>
    <p class="mb-8 leading-relaxed max-w-[400px] mx-auto" style="font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 400; color: #9B8778;">{{ section.settings.subheading }}</p>
    <a class="inline-block uppercase tracking-[0.2em] transition-all hover:bg-charcoal/90" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" style="background-color: #C8A46A; color: #F5F1EB; font-family: 'Montserrat', sans-serif; font-weight: 600; border-radius: 2px; padding: 16px 32px; font-size: 12px;">{{ section.settings.button_text }}</a>
  </div>
</section>

<style>
  .relative { position: relative; }
  .absolute { position: absolute; }
  .inset-0 { inset: 0; }
  .z-0 { z-index: 0; }
  .z-10 { z-index: 10; }
  .flex { display: flex; }
  .flex-col { flex-direction: column; }
  .items-center { align-items: center; }
  .justify-center { justify-content: center; }
  .text-center { text-align: center; }
  .overflow-hidden { overflow: hidden; }
  .min-h-\[70vh\] { min-height: 70vh; }
  .px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
  .pt-4 { padding-top: 1rem; }
  .w-full { width: 100%; }
  .h-full { height: 100%; }
  .object-cover { object-fit: cover; }
  .opacity-70 { opacity: 0.70; }
  .mix-blend-multiply { mix-blend-mode: multiply; }
  .bg-gradient-to-b { background-image: linear-gradient(to bottom, rgba(245,241,235,0.2), rgba(245,241,235,0.4), #F5F1EB); }
  .max-w-xl { max-width: 36rem; }
  .text-\[9px\] { font-size: 9px; }
  .uppercase { text-transform: uppercase; }
  .tracking-\[0\.5em\] { letter-spacing: 0.5em; }
  .text-primary { color: #C8A46A; }
  .mb-4 { margin-bottom: 1rem; }
  .block { display: block; }
  .font-semibold { font-weight: 600; }
  .font-display { font-family: 'Montserrat', sans-serif; }
  .mb-6 { margin-bottom: 1.5rem; }
  .italic { font-style: italic; }
  .leading-\[1\.1\] { line-height: 1.1; }
  .tracking-tight { letter-spacing: -0.025em; }
  .mb-8 { margin-bottom: 2rem; }
  .leading-relaxed { line-height: 1.625; }
  .max-w-\[400px\] { max-width: 400px; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .inline-block { display: inline-block; }
  .tracking-\[0\.2em\] { letter-spacing: 0.2em; }
  .transition-all { transition: all 0.3s ease; }
  .hero-heading { font-size: 42px; }
  @media (min-width: 640px) { .hero-heading { font-size: 58px; } }
  @media (min-width: 1024px) { .hero-heading { font-size: 72px; } }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Luxury perfume bottle detail"
    },
    {
      "type": "text",
      "id": "accent_text",
      "label": "Accent text",
      "default": "The Resale Collective"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Every scent has a story to tell twice."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A curated archive of pre-loved luxury fragrances for the discerning nose."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focal point (mobile)",
      "default": "center center",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "top center", "label": "Top" },
        { "value": "bottom center", "label": "Bottom" },
        { "value": "center left", "label": "Left" },
        { "value": "center right", "label": "Right" }
      ]
    }
  ],
  "presets": [
    { "name": "Hero Banner" }
  ]
}
{% endschema %}
