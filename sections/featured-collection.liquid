{%- assign col_handle = section.settings.collection -%}
{%- assign col = collections[col_handle] -%}
{%- assign products_to_show = section.settings.products_to_show | default: 4 -%}

<section class="featured-collection-section" data-section-id="{{ section.id }}">
  <div class="treasured-finds__container">
    <h3 class="treasured-finds__title">{{ section.settings.title | default: "Treasured Finds" }}</h3>

    <div class="treasured-finds__grid">
      {%- if col != blank and col.products.size > 0 -%}
        {%- for product in col.products limit: products_to_show -%}
          <a href="{{ product.url }}" class="treasured-find-card group">
            <div class="treasured-find-card__img-wrapper">
              {%- if product.featured_image -%}
                <img class="treasured-find-card__image" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" width="600" height="750" loading="lazy">
              {%- else -%}
                <div class="w-full h-full" style="background: #ece9e6;"></div>
              {%- endif -%}
              
              {%- liquid
                assign badge_text = ''
                for tag in product.tags
                  if tag contains 'badge:'
                    assign badge_text = tag | remove: 'badge:'
                  endif
                endfor
              -%}
              {%- if badge_text != blank -%}
                <div class="treasured-find-card__badge">{{ badge_text }}</div>
              {%- elsif product.compare_at_price > product.price -%}
                <div class="treasured-find-card__badge">Sale</div>
              {%- endif -%}
            </div>
            <p class="treasured-find-card__brand">{{ product.vendor }}</p>
            <h4 class="treasured-find-card__title">{{ product.title }}</h4>
            <p class="treasured-find-card__price">
              {{ product.price | money }}
              {%- if product.compare_at_price > product.price -%}
                <span class="line-through treasured-find-card__price--compare">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </p>
          </a>
        {%- endfor -%}
        {%- else -%}
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- assign block_url = routes.all_products_collection_url -%}
              {%- if block.settings.product != blank -%}
                {%- assign block_url = block.settings.product.url -%}
              {%- elsif block.settings.url != blank -%}
                {%- assign block_url = block.settings.url -%}
              {%- endif -%}
              <a href="{{ block_url }}" class="treasured-find-card group" {{ block.shopify_attributes }}>
                <div class="treasured-find-card__img-wrapper">
                  {%- if block.settings.product != blank and block.settings.product.featured_image -%}
                    <img class="treasured-find-card__image" src="{{ block.settings.product.featured_image | image_url: width: 600 }}" alt="{{ block.settings.product.title | escape }}" width="600" height="750" loading="lazy">
                  {%- elsif block.settings.image != blank -%}
                    <img class="treasured-find-card__image" src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" width="600" height="750" loading="lazy">
                  {%- elsif block.settings.image_url != blank -%}
                    <img class="treasured-find-card__image" src="{{ block.settings.image_url }}" alt="{{ block.settings.title | escape }}" width="600" height="750" loading="lazy">
                  {%- else -%}
                    <div class="w-full h-full" style="background: #ece9e6;"></div>
                  {%- endif -%}
                  {%- if block.settings.badge != blank -%}
                    <div class="treasured-find-card__badge">{{ block.settings.badge }}</div>
                  {%- endif -%}
                </div>
                {%- assign display_brand = block.settings.brand -%}
                {%- assign display_title = block.settings.title -%}
                {%- assign display_price = block.settings.price -%}
                {%- if block.settings.product != blank -%}
                  {%- assign display_brand = block.settings.brand | default: block.settings.product.vendor -%}
                  {%- assign display_title = block.settings.title | default: block.settings.product.title -%}
                  {%- assign display_price = block.settings.product.price | money -%}
                {%- endif -%}
                <p class="treasured-find-card__brand">{{ display_brand }}</p>
                <h4 class="treasured-find-card__title">{{ display_title }}</h4>
                <p class="treasured-find-card__price">
                  {{ display_price }}
                  {%- if block.settings.compare_price != blank -%}
                    <span class="line-through treasured-find-card__price--compare">{{ block.settings.compare_price }}</span>
                  {%- endif -%}
                </p>
              </a>
            {%- endfor -%}
          {%- endif -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and col != blank -%}
      <div class="treasured-finds__view-all">
        <a href="{{ col.url }}" class="btn btn-secondary">
          {{ 'actions.view_all' | t | default: 'View All' }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .featured-collection-section {
    padding: 4.5rem 1.5rem; /* py-18 px-6 */
    background-color: rgba(231, 221, 212, 0.3); /* bg-pearl-beige/30 */
  }
  
  .treasured-finds__container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .treasured-finds__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.25rem; /* text-4xl */
    font-style: italic;
    letter-spacing: -0.025em; /* tracking-tight */
    text-align: center;
    color: #2E2A33;
    margin-top: 0;
    margin-bottom: 3rem; /* mb-12 */
    font-weight: 400;
  }

  .treasured-finds__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem; /* gap-4 */
    row-gap: 2.5rem; /* gap-y-10 */
  }

  @media (min-width: 768px) {
    .treasured-finds__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .treasured-find-card {
    background-color: #E7DDD4;
    padding: 12px;
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    box-sizing: border-box;
  }

  .treasured-find-card__img-wrapper {
    aspect-ratio: 4/5;
    background-color: #ece9e6;
    margin-bottom: 1rem;
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .treasured-find-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2);
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .treasured-find-card:hover .treasured-find-card__image {
    transform: scale(1.05);
  }

  .treasured-find-card__badge {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    background-color: #ffffff;
    padding: 0.25rem 0.5rem;
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: -0.05em; /* tracking-tighter */
    color: #2D2926;
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    line-height: 1;
  }

  .treasured-find-card__brand {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em; /* tracking-widest */
    color: #C8A46A; /* text-primary */
    font-weight: 700;
    margin: 0 0 0.25rem 0;
  }

  .treasured-find-card__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.125rem; /* text-lg */
    margin: 0 0 0.25rem 0;
    font-weight: 400;
    color: #2D2926;
    line-height: 1.3;
  }

  .treasured-find-card__price {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem; /* text-xs */
    color: #9B8778;
    margin: 0;
    font-weight: 500;
  }

  .treasured-find-card__price--compare {
    margin-left: 0.5rem;
    opacity: 0.5;
    text-decoration: line-through;
  }

  .treasured-finds__view-all {
    text-align: center;
    margin-top: 2.5rem;
  }
</style>

