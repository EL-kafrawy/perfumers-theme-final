{%- comment -%}
  main-cart.liquid
  Rendered server-side from Liquid; cart CRUD (qty change, remove) is
  handled by cart-page.js via fetch('/cart/change.js').
{%- endcomment -%}

<section class="main-cart section" data-section-id="{{ section.id }}">
  <div class="container">

    <h1 class="main-cart__heading">{{ 'cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}

      <div class="main-cart__layout">

        {%- comment -%} ---- Left: line items ---- {%- endcomment -%}
        <div class="main-cart__items" id="cart-items-container">
          {%- for item in cart.items -%}
            <div class="cart-item" data-cart-item data-key="{{ item.key }}">

              {%- comment -%} Product image {%- endcomment -%}
              <a href="{{ item.url }}" class="cart-item__image-link" tabindex="-1" aria-hidden="true">
                {%- if item.image -%}
                  <img
                    src="{{ item.image | image_url: width: 300 }}"
                    alt="{{ item.image.alt | default: item.title | escape }}"
                    class="cart-item__image"
                    width="150"
                    height="200"
                    loading="lazy"
                  >
                {%- else -%}
                  <div class="cart-item__image cart-item__image--placeholder">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {%- endif -%}
              </a>

              {%- comment -%} Product details {%- endcomment -%}
              <div class="cart-item__details">
                <div class="cart-item__top">
                  <div>
                    <p class="cart-item__vendor">{{ item.vendor }}</p>
                    <a href="{{ item.url }}" class="cart-item__title">{{ item.product_title }}</a>
                    {%- if item.variant_title != 'Default Title' and item.variant_title != blank -%}
                      <p class="cart-item__variant">{{ item.variant_title }}</p>
                    {%- endif -%}
                  </div>
                  <button
                    type="button"
                    class="cart-item__remove"
                    data-cart-remove
                    data-line-key="{{ item.key }}"
                    aria-label="Remove {{ item.title | escape }}"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </button>
                </div>

                <div class="cart-item__bottom">
                  {%- comment -%} Quantity controls {%- endcomment -%}
                  <div class="cart-item__qty-wrap">
                    <div class="cart-item__qty quantity-selector" role="group" aria-label="Quantity for {{ item.title | escape }}">
                      <button
                        type="button"
                        class="quantity-selector__btn"
                        data-cart-qty-minus
                        aria-label="Decrease quantity"
                      >
                        {% render 'icon-minus' %}
                      </button>
                      <input
                        type="number"
                        class="quantity-selector__input"
                        data-cart-qty
                        data-line-key="{{ item.key }}"
                        value="{{ item.quantity }}"
                        min="1"
                        max="99"
                        aria-label="Quantity"
                      >
                      <button
                        type="button"
                        class="quantity-selector__btn"
                        data-cart-qty-plus
                        aria-label="Increase quantity"
                      >
                        {% render 'icon-plus' %}
                      </button>
                    </div>
                  </div>

                  {%- comment -%} Line price {%- endcomment -%}
                  <p class="cart-item__price" data-line-price>
                    {{ item.final_line_price | money }}
                  </p>
                </div>
              </div>

            </div>
          {%- endfor -%}
        </div>

        {%- comment -%} ---- Right: order summary ---- {%- endcomment -%}
        <aside class="main-cart__summary" id="cart-summary" aria-label="Order summary">
          <div class="cart-summary__inner">

            <h2 class="cart-summary__heading">Order Summary</h2>

            <div class="cart-summary__row">
              <span>Subtotal</span>
              <span data-cart-total>{{ cart.total_price | money }}</span>
            </div>

            <p class="cart-summary__note">{{ 'cart.shipping_note' | t }}</p>

            {%- if section.settings.show_order_note -%}
              <div class="cart-summary__note-field">
                <label for="cart-note" class="cart-summary__label">
                  {{ 'cart.note' | t }}
                </label>
                <textarea
                  id="cart-note"
                  name="note"
                  class="cart-summary__textarea"
                  rows="3"
                  placeholder="Add a note to your order..."
                  form="cart-form"
                ></textarea>
              </div>
            {%- endif -%}

            <form id="cart-form" action="{{ routes.cart_url }}" method="post">
              {%- if section.settings.show_order_note -%}
                <input type="hidden" name="note" value="{{ cart.note | escape }}">
              {%- endif -%}
              <button type="submit" name="checkout" class="btn btn-primary cart-summary__checkout">
                {{ 'cart.checkout' | t }}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
            </form>

            <a href="{{ routes.all_products_collection_url }}" class="cart-summary__continue">
              {{ 'cart.continue_shopping' | t }}
            </a>

          </div>
        </aside>

      </div>

    {%- else -%}

      {%- comment -%} ---- Empty state ---- {%- endcomment -%}
      <div class="main-cart__empty">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--color-mauve)" stroke-width="1" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        <p class="main-cart__empty-title">{{ 'cart.empty' | t }}</p>
        <p class="main-cart__empty-sub">Your cart is waiting to be filled with something beautiful.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">
          {{ 'cart.continue_shopping' | t }}
        </a>
      </div>

    {%- endif -%}

  </div>
</section>

<script src="{{ 'cart-page.js' | asset_url }}" defer="defer"></script>

<style>
  /* ============================================
     CART PAGE — Main Cart Section
     ============================================ */

  .main-cart {
    padding: var(--space-3xl) 0 var(--space-4xl);
    min-height: 60vh;
  }

  .main-cart__heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 300;
    color: var(--color-charcoal);
    margin-bottom: var(--space-2xl);
    letter-spacing: 0.02em;
  }

  /* ---- Layout ---- */
  .main-cart__layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .main-cart__layout {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-3xl);
    }

    .main-cart__items {
      flex: 1 1 auto;
    }

    .main-cart__summary {
      flex: 0 0 320px;
      position: sticky;
      top: 90px;
    }
  }

  /* ---- Cart Item ---- */
  .cart-item {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--color-pearl);
  }

  .cart-item__image-link {
    display: block;
    flex-shrink: 0;
  }

  .cart-item__image {
    width: 100px;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--radius-sm);
    display: block;
  }

  .cart-item__image--placeholder {
    background: var(--color-pearl);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-item__details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cart-item__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .cart-item__vendor {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-bottom: var(--space-xs);
  }

  .cart-item__title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 400;
    color: var(--color-charcoal);
    text-decoration: none;
    line-height: 1.3;
    display: block;
  }

  .cart-item__title:hover {
    color: var(--color-gold);
  }

  .cart-item__variant {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  .cart-item__remove {
    background: none;
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    padding: var(--space-xs);
    line-height: 1;
    flex-shrink: 0;
    transition: color var(--transition-fast);
  }

  .cart-item__remove:hover {
    color: var(--color-charcoal);
  }

  .cart-item__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .cart-item__price {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-charcoal);
  }

  /* ---- Summary Panel ---- */
  .cart-summary__inner {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
  }

  .cart-summary__heading {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-charcoal);
    margin-bottom: var(--space-xl);
    letter-spacing: 0.05em;
  }

  .cart-summary__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-charcoal);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-pearl);
  }

  .cart-summary__note {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    text-align: center;
    margin-bottom: var(--space-xl);
    line-height: 1.5;
  }

  .cart-summary__checkout {
    width: 100%;
    margin-bottom: var(--space-md);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
  }

  .cart-summary__continue {
    display: block;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .cart-summary__continue:hover {
    color: var(--color-charcoal);
  }

  .cart-summary__label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-charcoal);
    margin-bottom: var(--space-sm);
  }

  .cart-summary__textarea {
    width: 100%;
    padding: var(--space-sm) var(--space-md);
    border: 1.5px solid var(--color-pearl);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    background: var(--color-background);
    resize: vertical;
    margin-bottom: var(--space-xl);
    transition: border-color var(--transition-fast);
  }

  .cart-summary__textarea:focus {
    outline: none;
    border-color: var(--color-gold);
  }

  /* ---- Empty State ---- */
  .main-cart__empty {
    text-align: center;
    padding: var(--space-4xl) var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .main-cart__empty svg {
    opacity: 0.5;
  }

  .main-cart__empty-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-charcoal);
    font-weight: 400;
  }

  .main-cart__empty-sub {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    max-width: 320px;
  }

  .main-cart__empty .btn {
    margin-top: var(--space-sm);
  }
</style>

{% schema %}
{
  "name": "Main Cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_order_note",
      "label": "Show order note field",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Main Cart"
    }
  ]
}
{% endschema %}
