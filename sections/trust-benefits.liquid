<section class="trust-benefits section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="section__header" data-animate>
      <h2 class="section__title">{%- if section.settings.title != blank -%}{{ section.settings.title }}{%- else -%}{{ 'sections.trust_benefits.title' | t }}{%- endif -%}</h2>
      <div class="divider"></div>
    </div>

    <div class="trust-badges">
      {%- for block in section.blocks -%}
        <div class="trust-badge-item" data-animate {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div class="trust-benefits__icon">
              <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="" loading="lazy">
            </div>
          {%- else -%}
            <div class="trust-benefits__icon trust-benefits__icon--default">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
          {%- endif -%}
          <h3 class="trust-benefits__title">{{ block.settings.title }}</h3>
          <p class="trust-benefits__desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .trust-benefits {
    background: var(--color-surface);
  }
  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    padding: 0 15px;
  }
  .trust-badge-item {
    flex: 1 1 40%;
    text-align: center;
    max-width: 150px;
    overflow: hidden;
  }
  .trust-benefits__icon {
    width: 64px;
    height: 64px;
    margin: 0 auto var(--space-md);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .trust-benefits__icon--default {
    color: var(--color-gold);
  }
  .trust-benefits__icon img {
    max-width: 48px;
    max-height: 48px;
  }
  .trust-benefits__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    color: var(--color-charcoal);
    margin-bottom: var(--space-sm);
  }
  .trust-benefits__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  @media (min-width: 768px) {
    .trust-badge-item {
      flex: 1 1 20%;
    }
  }
</style>

{% schema %}
{
  "name": "Trust & Benefits",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Why PERFUMERS"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% Authentic"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Every product is guaranteed authentic"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Custom icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust & Benefits",
      "blocks": [
        { "type": "benefit", "settings": { "title": "100% Authentic", "description": "Every product is guaranteed authentic" }},
        { "type": "benefit", "settings": { "title": "Fast Delivery", "description": "Across Egypt" }},
        { "type": "benefit", "settings": { "title": "Easy Returns", "description": "14-day return policy" }},
        { "type": "benefit", "settings": { "title": "Expert Support", "description": "Fragrance consultants available" }}
      ]
    }
  ]
}
{% endschema %}
