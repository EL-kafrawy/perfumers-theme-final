<section class="product-info section" data-section-id="{{ section.id }}">
  <div class="container">
    {% render 'breadcrumb' %}

    <div class="product-info__wrapper">
      <!-- Product JSON Data -->
      <script type="application/json" data-product-json>{{ product | json }}</script>

      <!-- Brand -->
      <p class="product-info__brand">{{ product.vendor }}</p>

      <!-- Title -->
      <h1 class="product-info__title">{{ product.title }}</h1>

      <!-- Price -->
      <div class="product-info__price-wrapper">
        {%- if product.compare_at_price > product.price -%}
          <span class="product-info__compare-price" data-product-compare-price>
            {% render 'price', price: product.compare_at_price %}
          </span>
        {%- endif -%}
        <span class="product-info__price" data-product-price>
          {% render 'price', price: product.price %}
        </span>
        {%- if product.compare_at_price > product.price -%}
          {%- assign savings = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
          <span class="product-info__savings">-{{ savings }}%</span>
        {%- endif -%}
      </div>

      <div class="gold-line"></div>

      <!-- Short Description -->
      {%- if product.metafields.custom.short_description != blank -%}
        <p class="product-info__short-desc">{{ product.metafields.custom.short_description }}</p>
      {%- endif -%}

      <!-- Product Form -->
      {%- form 'product', product, data-product-form: '' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <!-- Volume / Variant Selection -->
        {%- if product.variants.size > 1 -%}
          <div class="product-info__variants">
            <p class="product-info__label">{{ 'product.select_volume' | t }}</p>
            <div class="product-info__volume-options">
              {%- for variant in product.variants -%}
                <button
                  type="button"
                  class="product-info__volume-btn{% if variant == product.selected_or_first_available_variant %} is-active{% endif %}{% unless variant.available %} is-sold-out{% endunless %}"
                  data-volume-option
                  data-variant-id="{{ variant.id }}"
                  {% unless variant.available %}disabled{% endunless %}
                >
                  {{ variant.title }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        <!-- Quantity -->
        <div class="product-info__quantity">
          <p class="product-info__label">{{ 'product.quantity' | t }}</p>
          {% render 'quantity-selector', value: 1 %}
        </div>

        <!-- Add to Cart -->
        <button
          type="submit"
          class="btn btn-primary product-info__add-btn"
          data-add-to-cart
          {% unless product.available %}disabled{% endunless %}
        >
          <span data-add-to-cart-text data-add-text="{{ 'actions.add_to_cart' | t }}" data-sold-out-text="{{ 'actions.sold_out' | t }}">
            {%- if product.available -%}
              {{ 'actions.add_to_cart' | t }}
            {%- else -%}
              {{ 'actions.sold_out' | t }}
            {%- endif -%}
          </span>
        </button>

        <!-- Buy Now -->
        {%- if section.settings.show_buy_now -%}
          <button type="submit" class="btn btn-secondary product-info__buy-now" data-buy-now>
            {{ 'actions.buy_now' | t }}
          </button>
        {%- endif -%}

        <!-- Trust Badges -->
        <div class="product-info__trust-badges">
          <div class="product-info__trust-badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>{{ 'product.trust_authentic' | t }}</span>
          </div>
          <div class="product-info__trust-badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            <span>{{ 'product.trust_delivery' | t }}</span>
          </div>
          <div class="product-info__trust-badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            <span>{{ 'product.trust_returns' | t }}</span>
          </div>
          <div class="product-info__trust-badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            <span>{{ 'product.trust_cod' | t }}</span>
          </div>
        </div>
      {%- endform -%}

      <!-- Product Meta -->
      <div class="product-info__meta">
        {%- if product.type != blank -%}
          <p class="product-info__meta-item">
            <span class="product-info__meta-label">{{ 'product.type' | t }}:</span>
            {{ product.type }}
          </p>
        {%- endif -%}
        {%- if product.sku != blank -%}
          <p class="product-info__meta-item">
            <span class="product-info__meta-label">{{ 'product.sku' | t }}:</span>
            {{ product.selected_or_first_available_variant.sku }}
          </p>
        {%- endif -%}
      </div>

      <!-- Description -->
      {%- if product.description != blank -%}
        <div class="product-info__description">
          <h3 class="product-info__desc-title">{{ 'product.description' | t }}</h3>
          <div class="product-info__desc-content">
            {{ product.description }}
          </div>
        </div>
      {%- endif -%}

      <!-- Delivery & Returns -->
      <div class="product-info__policies">
        <div class="product-info__policy">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <div>
            <strong>{{ 'product.delivery' | t }}</strong>
            <p class="text-sm text-muted">{{ section.settings.delivery_text }}</p>
          </div>
        </div>
        <div class="product-info__policy">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>
          <div>
            <strong>{{ 'product.returns' | t }}</strong>
            <p class="text-sm text-muted">{{ section.settings.returns_text }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'product-page.js' | asset_url }}" defer></script>

<style>
  .product-info__brand {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xs);
  }
  .product-info__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--font-light);
    color: var(--color-charcoal);
    margin-bottom: var(--space-md);
    line-height: 1.2;
  }
  .product-info__price-wrapper {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }
  .product-info__price {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--color-charcoal);
  }
  .product-info__compare-price {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    text-decoration: line-through;
  }
  .product-info__savings {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-gold);
    background: var(--color-gold-10);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
  }
  .product-info__short-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
    line-height: 1.6;
  }
  .product-info__label {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-charcoal);
    margin-bottom: var(--space-sm);
  }
  .product-info__variants {
    margin-bottom: var(--space-xl);
  }
  .product-info__volume-options {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .product-info__volume-btn {
    padding: var(--space-sm) var(--space-lg);
    border: 1.5px solid var(--color-pearl);
    background: transparent;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-charcoal);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }
  .product-info__volume-btn.is-active {
    border-color: var(--color-gold);
    background: var(--color-gold-10);
    color: var(--color-gold);
  }
  .product-info__volume-btn.is-sold-out {
    opacity: 0.4;
    cursor: not-allowed;
    text-decoration: line-through;
  }
  .product-info__quantity {
    margin-bottom: var(--space-xl);
  }
  .product-info__add-btn {
    margin-bottom: var(--space-sm);
  }
  .product-info__buy-now {
    margin-bottom: var(--space-xl);
  }
  .product-info__trust-badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(0,0,0,0.08);
    margin-bottom: var(--space-xl);
  }
  .product-info__trust-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--color-taupe, #7E6C5F);
  }
  .product-info__trust-badge svg {
    color: var(--color-gold, #C8A46A);
  }
  .product-info__trust-badge svg {
    flex-shrink: 0;
  }
  .product-info__meta {
    padding: var(--space-md) 0;
    border-top: 1px solid var(--color-pearl);
    border-bottom: 1px solid var(--color-pearl);
    margin-bottom: var(--space-xl);
  }
  .product-info__meta-item {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xs);
  }
  .product-info__meta-label {
    font-weight: var(--font-medium);
    color: var(--color-charcoal);
  }
  .product-info__description {
    margin-bottom: var(--space-xl);
  }
  .product-info__desc-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-md);
  }
  .product-info__desc-content {
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text-secondary);
  }
  .product-info__policies {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-xl);
    background: var(--color-surface);
    border-radius: var(--radius-md);
  }
  .product-info__policy {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    color: var(--color-charcoal);
  }
  .product-info__policy svg {
    flex-shrink: 0;
    margin-top: 2px;
  }
  .product-info__policy strong {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-xs);
  }
  @media (min-width: 1024px) {
    .product-info__wrapper {
      max-width: 560px;
    }
  }
</style>

{% schema %}
{
  "name": "Product Info",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "Show Buy Now button",
      "default": true
    },
    {
      "type": "text",
      "id": "delivery_text",
      "label": "Delivery info",
      "default": "2-5 business days across Egypt"
    },
    {
      "type": "text",
      "id": "returns_text",
      "label": "Returns info",
      "default": "14-day hassle-free returns"
    }
  ],
  "presets": [
    {
      "name": "Product Info"
    }
  ]
}
{% endschema %}
