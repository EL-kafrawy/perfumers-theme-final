{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'collection'
    assign og_type = 'website'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif

  if page_image
    assign og_image = page_image
  elsif request.page_type == 'product' and product.images.size > 0
    assign og_image = product.images.first
  elsif request.page_type == 'article' and article.image
    assign og_image = article.image
  elsif request.page_type == 'collection' and collection.image
    assign og_image = collection.image
  endif
-%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if og_image -%}
  <meta property="og:image" content="{{ og_image | image_url: width: 1200, height: 630 }}">
  <meta property="og:image:secure_url" content="{{ og_image | image_url: width: 1200, height: 630 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">

{%- if og_image -%}
  <meta name="twitter:image" content="{{ og_image | image_url: width: 1200, height: 630 }}">
  <meta name="twitter:image:width" content="1200">
  <meta name="twitter:image:height" content="630">
{%- endif -%}
